# Alternative to the Caddyfile if you prefer nginx. TLS here is via certbot
# (`certbot --nginx -d api.yourapp.com`), which writes the ssl_certificate lines for you.
server {
    listen 80;
    server_name api.yourapp.com;
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl;
    server_name api.yourapp.com;

    # certbot fills these in:
    ssl_certificate     /etc/letsencrypt/live/api.yourapp.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.yourapp.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8787;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
