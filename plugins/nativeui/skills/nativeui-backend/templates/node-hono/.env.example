# Copy to .env (git-ignored) and fill in. The server reads these from process.env.
# Never commit real secrets — the exported app is decompilable, so third-party keys live ONLY here.

# Port the server binds to. Cloud Run / Render / Fly inject their own PORT; this is the local default.
PORT=8787

# Comma-separated app origins allowed via CORS, or * in dev.
# Native fetch from a device/simulator sends no Origin, so this only gates browser callers.
ALLOWED_ORIGINS=*

# Example third-party secret used by your endpoints. Add one line per secret your routes need.
API_KEY=
