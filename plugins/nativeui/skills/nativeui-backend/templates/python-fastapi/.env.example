# Copy to .env and fill in. Loaded by pydantic-settings (env_prefix="NUI_").
# .env is for LOCAL dev — never commit real secrets; set these as real env
# vars / secrets on your deploy target (Cloud Run, Fly, Render, ...).

# Browser origins allowed to call this server (comma-separated). "*" for local
# dev. Native iOS/Android apps are NOT subject to CORS — this only matters for a
# web build or the NativeUI editor preview hitting the same endpoints.
NUI_CORS_ORIGINS=*

# Example server-side secret. Keep third-party keys HERE, never in the exported
# app (it ships to devices and is decompilable). The app calls this server; this
# server holds the key.
NUI_API_KEY=
